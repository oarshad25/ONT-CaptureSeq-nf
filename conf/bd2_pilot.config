// test profile for providing pipeline parameters to run on bd2-pilot2 dataset


params {
    // Input data
    inputdir = "/well/pharrison/users/piz649/projects/bd2_pilot2/analysis/01_primary/demux_reads/results/output_reads"

    // *genome references*

    // merged gencode and SIRVome
    genome = "/well/pharrison/users/piz649/projects/bd2_pilot2/analysis/02_prep_input_secondary_analysis/results/references/merged/merged.fa"
    annotation = "/well/pharrison/users/piz649/projects/bd2_pilot2/analysis/02_prep_input_secondary_analysis/results/references/merged/merged.gtf"

    // results directory
    outdir = "results-bd2pilot2"

    // path to transcriptome FASTA for optional transcript quantification with Oarfish
    // if null or empty, Oarfish is not run
    transcriptome = "/well/pharrison/users/piz649/projects/bd2_pilot2/analysis/02_prep_input_secondary_analysis/results/references/merged/merged.transcripts.fa"

    // threshold for minimum number of reads that sample must contain
    // samples with number of reads below this threshold are discarded
    // this is mainly to get rid of unassigned barcodes
    min_reads_per_sample = 10000

    // path to file of list of genes in capture target panel
    panel_gene_list = "/well/pharrison/users/piz649/projects/bd2_pilot2/analysis/02_prep_input_secondary_analysis/results/metadata/capture_genes_list.txt"

    // path to optional file of list of a few genes of particular interest whose read stats are to be included in multiqc
    goi_gene_list = "${projectDir}/assets/genes_of_interest.txt"

    /*
    Provide tool input and/or override default tool options
    =================
    */

    // *read filtering options*

    // maximum read length to keep
    max_length = 35000

    // *cDNA QC*

    pychopper_cdna_kit = "LSK114"
    //cdna_qc_method = "restrander"
    //restrander_config = "${projectDir}/assets/restrander_config/DCS-LSK114.json"

    //*minimap*
    minimap2_G = "500k"

    // path to RSeQC housekeeping genes BED file to run RSeQC geneBody_coverage.py module
    rseqc_housekeeping_bed = "/well/pharrison/users/piz649/projects/bd2_pilot2/analysis/02_prep_input_secondary_analysis/results/references/rseqc/hg38.HouseKeepingGenes.bed"

    // Whether to skip running isoform discovery with isoquant or flair
    skip_isoform_discovery = true
}
